JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=xxxxx
JIRA_JQL=assignee = currentUser() AND statusCategory != Done
JIRA_PROJECT_KEY=ABC
JIRA_ISSUE_TYPE=Task

# Optional: define multiple board / issue-type sections in sections.json
# (gitignored; copy sections.example.json). When present it overrides the
# single JIRA_JQL/JIRA_PROJECT_KEY/JIRA_ISSUE_TYPE section above.
# Credentials (URL/email/token) always come from this .env and are shared.
